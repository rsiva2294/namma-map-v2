{
  "name": "v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "update-version": "node -e \"const fs = require('fs'); const v = new Date().toISOString(); fs.writeFileSync('public/version.json', JSON.stringify({version: v})); const app = fs.readFileSync('src/App.tsx', 'utf8'); fs.writeFileSync('src/App.tsx', app.replace(/const APP_VERSION = '.*';/, 'const APP_VERSION = \\'' + v + '\\';'));\"",
    "build": "npm run update-version && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "framer-motion": "^12.38.0",
    "geojson-vt": "^4.0.2",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "leaflet.vectorgrid": "^1.3.0",
    "lucide-react": "^1.8.0",
    "rbush": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "topojson-client": "^3.1.0",
    "vt-pbf": "^3.1.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/geojson-vt": "^3.2.5",
    "@types/node": "^24.12.2",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
